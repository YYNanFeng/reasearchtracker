{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["key", "title", "authors", "year"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "const": "reference" },
    "key": { "type": "string" },
    "title": { "type": "string" },
    "authors": { "type": "string" },
    "year": { "type": "integer" },
    "venue": { "type": "string" },
    "url": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
